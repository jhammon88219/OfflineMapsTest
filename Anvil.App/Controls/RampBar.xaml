<?xml version="1.0" encoding="utf-8"?>
<!-- RampBar — a radar product's color scale as a compact bar: the ramp itself (generated from the WebView's
     own stops via RampToBrushConverter, so it can't drift from the painted gates), the min/max values under
     it, and the live Inspect tick. Hovering the bar reads the value at that point (a tooltip), which is why
     this is a CONTROL and not just a Style — a Style can't carry pointer logic.

     It's the legend, folded into the Product combo (see ProductRampComboBoxStyle): the selected product's
     bar renders inside the closed combo, so the selector IS the scale and the separate Color Scale section
     goes away. `ShowScale` off gives just the ramp (what the dropdown rows use). -->
<UserControl
    x:Class="Anvil.Controls.RampBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" RowSpacing="3" SizeChanged="OnLayoutSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- ramp + inspect tick -->
            <RowDefinition Height="Auto"/> <!-- min / max values (ShowScale) -->
        </Grid.RowDefinitions>

        <!-- Bar + tick share one cell. The tick is placed by proportional star columns, so it tracks the
             value at any bar width. A muted "ghost" holds the footprint until a ramp is known.
             Its size also feeds StripAlignMargin, so siblings can line up with the STRIP (see the
             code-behind) rather than with this control's overall centre. -->
        <Grid x:Name="BarHost" Grid.Row="0" Height="11"
              SizeChanged="OnLayoutSizeChanged"
              PointerMoved="OnBarPointerMoved"
              PointerExited="OnBarPointerExited">
            <Border CornerRadius="2"
                    BorderThickness="0.5"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    Visibility="{x:Bind GhostVisibility(Ramp), Mode=OneWay}"/>
            <Border CornerRadius="2"
                    BorderThickness="0.5"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{x:Bind RampBrush(Ramp), Mode=OneWay}"
                    Visibility="{x:Bind VisibleWhen(HasRamp), Mode=OneWay}"/>

            <!-- Live Inspect marker: a thin tick at the cursor value's fraction along the ramp. -->
            <Grid Visibility="{x:Bind VisibleWhen(IsInspectVisible), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{x:Bind LeftStar(InspectFraction), Mode=OneWay}"/>
                    <ColumnDefinition Width="{x:Bind RightStar(InspectFraction), Mode=OneWay}"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1"
                        Width="2"
                        Height="15"
                        HorizontalAlignment="Left"
                        Margin="-1,0,0,0"
                        Background="{ThemeResource TextFillColorPrimaryBrush}"/>
            </Grid>
        </Grid>

        <!-- min … max, with the unit on the max end so the numbers are self-describing. -->
        <Grid Grid.Row="1" Visibility="{x:Bind VisibleWhen(ShowScale), Mode=OneWay}">
            <TextBlock Text="{x:Bind ScaleMin(Ramp), Mode=OneWay}"
                       FontSize="11"
                       HorizontalAlignment="Left"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="{x:Bind ScaleMax(Ramp), Mode=OneWay}"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
