<?xml version="1.0" encoding="utf-8"?>
<!-- AppSettingsCard — the app-wide settings card, the RIGHT-side mirror of the temporal cards. Hosted in
     the OverlayBar's SettingsCardHost slot (above the bar, right-aligned) and opened by the settings cog
     on the bar's right edge; hidden by the card's own down-triangle. Uses the SAME ControlCard chrome
     (fixed size, down-triangle) as the temporal cards, so the UX is symmetrical: temporal settings open on
     the left, app settings on the right. This is the app-wide settings area; sections stack in the body as
     [section label] over its controls. Today: a "Radar Settings" section with the Show Research Radars
     toggle (the Show TDWRs toggle lands here later). Bound to the coordinator MapViewModel. -->
<UserControl x:Class="Anvil.Controls.Sections.AppSettingsCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="using:Anvil.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Section header inside the settings body (e.g. "Radar Settings"). -->
        <Style x:Key="SettingsSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CharacterSpacing" Value="40"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ctl:ControlCard Title="Settings"
                         CloseRequested="OnCardCloseRequested"
                         Visibility="{x:Bind VisibleWhen(ViewModel.IsSettingsCardOpen), Mode=OneWay}">
            <ctl:ControlCard.CardBody>
                <!-- Body: one section per group, [label] over its controls. Grid rows (no StackPanels). -->
                <Grid RowSpacing="8" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- section label: Radar Settings -->
                        <RowDefinition Height="Auto"/> <!-- Show TDWRs -->
                        <RowDefinition Height="Auto"/> <!-- Show Research Radars -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Radar Settings"
                               Style="{StaticResource SettingsSectionLabelStyle}"/>

                    <!-- Opt-in TDWRs (the FAA Terminal Doppler Weather Radar T*** network). -->
                    <CheckBox Grid.Row="1"
                              Margin="4,0,0,0"
                              Content="Show TDWRs"
                              IsChecked="{x:Bind ViewModel.Radar.ShowTdwrs, Mode=TwoWay}"
                              ToolTipService.ToolTip="Show FAA Terminal Doppler Weather Radar markers (e.g. TOKC, TDAL)"/>

                    <!-- Opt-in research/test radars (e.g. the ROC test bed KCRI). Moved here from the radar
                         console so app-wide toggles live in one place. -->
                    <CheckBox Grid.Row="2"
                              Margin="4,0,0,0"
                              Content="Show Research Radars"
                              IsChecked="{x:Bind ViewModel.Radar.ShowResearchRadars, Mode=TwoWay}"
                              ToolTipService.ToolTip="Show research/test radar markers such as KCRI (ROC test bed, Norman OK)"/>
                </Grid>
            </ctl:ControlCard.CardBody>
        </ctl:ControlCard>
    </Grid>
</UserControl>
