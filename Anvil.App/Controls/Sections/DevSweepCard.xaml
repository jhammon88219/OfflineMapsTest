<?xml version="1.0" encoding="utf-8"?>
<!-- DevSweepCard — DEV-ONLY. The params + run controls for the automated site sweep (SiteSweepViewModel),
     floating above the OverlayBar like the app settings card and using the same ControlCard chrome. Opened
     by the dev "Sweep" button on the bar's right edge (visible only in Debug builds). Non-modal so the map
     keeps rendering during a run (the sweep needs the WebView decoding frames). The finished report opens
     in SweepReportDialog (Save / Close). Bound to a SiteSweepViewModel; see docs/app-notes.md (Dev/testing). -->
<UserControl x:Class="Anvil.Controls.Sections.DevSweepCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="using:Anvil.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <ctl:ControlCard Title="Site sweep (dev)"
                         CloseRequested="OnCardCloseRequested"
                         Visibility="{x:Bind VisibleWhen(IsCardOpen), Mode=OneWay}">
            <ctl:ControlCard.CardBody>
                <Grid RowSpacing="8" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- status / live countdown (TOP so it can't clip) -->
                        <RowDefinition Height="Auto"/> <!-- dwell + timeout -->
                        <RowDefinition Height="Auto"/> <!-- frames-per-site -->
                        <RowDefinition Height="Auto"/> <!-- scope checkboxes -->
                        <RowDefinition Height="Auto"/> <!-- start/stop + report -->
                    </Grid.RowDefinitions>

                    <!-- Live status + per-second dwell countdown. Prominent, at the top, always visible. -->
                    <Border Grid.Row="0" CornerRadius="6" Padding="10,7"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Text="{x:Bind SweepVm.StatusText, Mode=OneWay}"/>
                    </Border>

                    <!-- Dwell + per-site timeout, side by side, compact (labels inline, no tall headers). -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dwell s" VerticalAlignment="Center" FontSize="12"/>
                        <NumberBox x:Name="DwellBox" Grid.Column="1"
                                   SpinButtonPlacementMode="Compact" SmallChange="5" LargeChange="30"
                                   Minimum="5" Maximum="600" ValueChanged="OnDwellChanged"/>
                        <TextBlock Grid.Column="2" Text="Timeout s" VerticalAlignment="Center" FontSize="12"/>
                        <NumberBox x:Name="TimeoutBox" Grid.Column="3"
                                   SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="30"
                                   Minimum="10" Maximum="1200" ValueChanged="OnTimeoutChanged"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Frames (0 = full dwell)"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <NumberBox x:Name="FramesBox" Grid.Column="1"
                                   SpinButtonPlacementMode="Compact" SmallChange="1" LargeChange="5"
                                   Minimum="0" Maximum="50" ValueChanged="OnFramesChanged"/>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="Operational only" IsChecked="{x:Bind SweepVm.OperationalOnly, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Operational WSR-88D only, by site class (excludes research + TDWR; still includes OCONUS operational sites — AK/HI/PR/overseas)"/>
                        <CheckBox Content="Skip offline" IsChecked="{x:Bind SweepVm.SkipOffline, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Skip sites the status feed reports down / no data"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                        <Button Content="Start" Click="OnStartClick"
                                IsEnabled="{x:Bind SweepVm.IsIdle, Mode=OneWay}"/>
                        <Button Content="Stop" Click="OnStopClick"
                                IsEnabled="{x:Bind SweepVm.IsRunning, Mode=OneWay}"/>
                        <Button Content="Report…" Click="OnReportClick"
                                IsEnabled="{x:Bind SweepVm.HasReport, Mode=OneWay}"/>
                    </StackPanel>
                </Grid>
            </ctl:ControlCard.CardBody>
        </ctl:ControlCard>
    </Grid>
</UserControl>
