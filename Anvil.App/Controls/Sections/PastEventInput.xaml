<?xml version="1.0" encoding="utf-8"?>
<!-- PastEventInput — the Past Event Viewer's date/start/window form, shown as the body of the PastCast
     settings card (floating above the overlay bar). Laid out ENTIRELY with grids (rows/columns, no
     StackPanels) so rows are easy to add/rearrange: a fixed [label | controls] outer grid, one row per
     field, and each multi-widget field is its own nested column grid. Date + window bind RadarViewModel
     indices directly; the editable hour/minute combos + AM/PM pair convert to/from the VM's PastEventTime
     (TimeSpan) in code-behind (element names HourCombo / MinuteCombo / AmCheck / PmCheck must stay).
     Bound to RadarViewModel. -->
<UserControl x:Class="Anvil.Controls.Sections.PastEventInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="PastLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <!-- Outer grid: label column + control column, one row per field. -->
    <Grid ColumnSpacing="12" RowSpacing="10" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Date -->
            <RowDefinition Height="Auto"/> <!-- Start time -->
            <RowDefinition Height="Auto"/> <!-- Window duration -->
            <RowDefinition Height="Auto"/> <!-- Load + status -->
        </Grid.RowDefinitions>

        <!-- Date: year / month / day. -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Date" Style="{StaticResource PastLabelStyle}"/>
        <Grid Grid.Row="0" Grid.Column="1" ColumnSpacing="6" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" Width="88" IsEditable="True"
                      ItemsSource="{x:Bind ViewModel.PastEventYearOptions}"
                      SelectedIndex="{x:Bind ViewModel.PastEventYearIndex, Mode=TwoWay}"/>
            <ComboBox Grid.Column="1" Width="64" IsEditable="True"
                      ItemsSource="{x:Bind ViewModel.PastEventMonthOptions}"
                      SelectedIndex="{x:Bind ViewModel.PastEventMonthIndex, Mode=TwoWay}"/>
            <ComboBox Grid.Column="2" Width="64" IsEditable="True"
                      ItemsSource="{x:Bind ViewModel.PastEventDayOptions}"
                      SelectedIndex="{x:Bind ViewModel.PastEventDayIndex, Mode=TwoWay}"/>
        </Grid>

        <!-- Start time: hour : minute + AM/PM pair. -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Start" Style="{StaticResource PastLabelStyle}"/>
        <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="6" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="HourCombo" Grid.Column="0" Width="64" IsEditable="True"
                      SelectionChanged="OnTimePartChanged" TextSubmitted="OnTimeTextSubmitted"/>
            <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" FontSize="14"/>
            <ComboBox x:Name="MinuteCombo" Grid.Column="2" Width="64" IsEditable="True"
                      SelectionChanged="OnTimePartChanged" TextSubmitted="OnTimeTextSubmitted"/>
            <CheckBox x:Name="AmCheck" Grid.Column="3" Content="AM" MinWidth="0" Margin="6,0,0,0" Click="OnAmClick"/>
            <CheckBox x:Name="PmCheck" Grid.Column="4" Content="PM" MinWidth="0" Click="OnPmClick"/>
        </Grid>

        <!-- Window duration. -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Window" Style="{StaticResource PastLabelStyle}"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Width="130" HorizontalAlignment="Left" IsEditable="True"
                  ItemsSource="{x:Bind ViewModel.PastEventDurationOptions}"
                  SelectedIndex="{x:Bind ViewModel.PastEventDurationIndex, Mode=TwoWay}"/>

        <!-- Load button + status text. -->
        <Grid Grid.Row="3" Grid.Column="1" ColumnSpacing="10" Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Load" Style="{ThemeResource AccentButtonStyle}" Click="OnLoadClick"/>
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PastEventStatus, Mode=OneWay}"
                       TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
