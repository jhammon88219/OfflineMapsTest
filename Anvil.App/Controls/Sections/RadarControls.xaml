<?xml version="1.0" encoding="utf-8"?>
<!-- RadarControls — the whole radar console in one control (one RadarViewModel). Three zones laid out
     entirely with Grids (no StackPanels):

       DISPLAY (left)  |  TRANSPORT (center)  |  SITE (right)

     Centering guarantee ("nothing shifts it, not even itself"): the root is a * | Auto | * grid, so the
     center Auto column — the transport cluster — is pinned to the exact horizontal midpoint of whatever
     width this control is given (the full bar, under the show/hide tab). The two * columns split the
     remaining space EQUALLY, so the transport can't move regardless of what the sides show; the Play
     button sits dead-center of the transport, so it lands directly under the tab. The Display cluster
     right-aligns against the transport and the Site cluster left-aligns against it (each a fixed width),
     so neither a long site name nor a wide combo can nudge the center. All bound to RadarViewModel. -->
<UserControl x:Class="Anvil.Controls.Sections.RadarControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Anvil.Controls"
             xmlns:vm="using:Anvil.ViewModels"
             mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="RightClusterFontSize">18</x:Double>
    </UserControl.Resources>

    <!-- Root: * | Auto | * — the Auto (transport) column is centered; the two * columns take the rest. -->
    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Center"
          ColumnSpacing="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>    <!-- left space; Display cluster hugs the transport -->
            <ColumnDefinition Width="Auto"/> <!-- center: transport (always midpoint-pinned) -->
            <ColumnDefinition Width="*"/>    <!-- right space; Site cluster grows into it -->
        </Grid.ColumnDefinitions>

        <!-- ============================ DISPLAY (left of transport) ============================
             Color-scale legend, Product/Tilt, and Sites/Inspect, stacked in Grid rows. Right-aligned at a
             fixed width so it counterweights the transport without ever changing the center. -->
        <Grid Grid.Column="0"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Width="350"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Product (carries its own ramp/legend) / Tilt -->
                <RowDefinition Height="Auto"/> <!-- Sites / Inspect -->
            </Grid.RowDefinitions>

            <!-- Product + Tilt share one row (equal columns). -->
            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Data-driven from ViewModel.RadarProductOptions (mirrors the JS radar-products.js
                     registry) so adding a product grows the dropdown with no XAML change. The style draws
                     each product's COLOR RAMP next to its short name — the selector IS the legend, which is
                     why there's no separate Color Scale block. The inspect tick rides the closed ramp, passed
                     in via the attached properties (a template can only bind its TemplatedParent). -->
                <controls:HandCursorComboBox Grid.Column="0"
                          Style="{StaticResource ProductRampComboBoxStyle}"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.RadarProductOptions}"
                          SelectedIndex="{x:Bind ViewModel.RadarProductIndex, Mode=TwoWay}"
                          controls:ProductRampCombo.InspectFraction="{x:Bind ViewModel.InspectFraction, Mode=OneWay}"
                          controls:ProductRampCombo.IsInspectVisible="{x:Bind ViewModel.IsInspectMarkerVisible, Mode=OneWay}"/>
                <!-- Tilt (elevation). Data-driven from ViewModel.RadarTiltOptions, which is read from the
                     VCP's elevation table carried in every cached tilt — so the choices are what this
                     radar actually scans right now, and they follow a VCP change. Disabled until a loop
                     offers more than one tilt (CanSelectTilt). Unlike Product, changing this RELOADS the
                     loop: each cached volume holds one tilt, so another elevation is different bytes. -->
                <controls:HandCursorComboBox Grid.Column="1"
                          Style="{StaticResource NoBackgroundComboBoxStyle}"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.RadarTiltOptions}"
                          DisplayMemberPath="Label"
                          SelectedIndex="{x:Bind ViewModel.RadarTiltIndex, Mode=TwoWay}"
                          IsEnabled="{x:Bind ViewModel.CanSelectTilt, Mode=OneWay}"
                          ToolTipService.ToolTip="Elevation angle (tilt)"/>
            </Grid>

            <!-- Show/hide sites + Inspect share one row (equal columns). -->
            <Grid Grid.Row="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Content="{x:Bind ViewModel.RadarSitesToggleLabel, Mode=OneWay}"
                        Click="OnToggleSitesClick"
                        ToolTipService.ToolTip="Show or hide the on-map radar site markers"/>
                <ToggleButton Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Content="Inspect"
                              IsChecked="{x:Bind ViewModel.IsInspecting, Mode=TwoWay}"
                              ToolTipService.ToolTip="Read the value under the cursor on the map, marked live on the color scale"/>
            </Grid>
        </Grid>

        <!-- ============================ TRANSPORT (center) ============================
             Play is pinned to the EXACT window midpoint and nothing shifts it: the root centers this Auto
             column between two equal * columns, and the button row is symmetric — the frame count (left)
             and time (right) sit in EQUAL-width columns flanking prev/play/next, so neither can nudge Play.
             The segmented scrubber spans the same width, so it's centered on the midpoint too.
             Row 0: x/x · prev · play · next · time. Row 1: segmented scrubber (its per-cell fill IS the
             load indicator for EVERY product — reflectivity decode and velocity dealias alike). -->
        <Grid Grid.Column="1"
              Width="360"
              VerticalAlignment="Center"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- x/x · prev · play · next · time -->
                <RowDefinition Height="Auto"/> <!-- segmented scrubber -->
            </Grid.RowDefinitions>

            <!-- Button row. The two 84px side columns are EQUAL, so Play (center column) lands on the exact
                 midpoint regardless of how wide the count / time text is. -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84"/>   <!-- frame count (right-aligned) -->
                    <ColumnDefinition Width="Auto"/> <!-- prev -->
                    <ColumnDefinition Width="Auto"/> <!-- play -->
                    <ColumnDefinition Width="Auto"/> <!-- next -->
                    <ColumnDefinition Width="84"/>   <!-- time (left-aligned) == count col, keeps Play centered -->
                </Grid.ColumnDefinitions>

                <!-- Frame N/M (current / total), left of the buttons. -->
                <TextBlock Grid.Column="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{x:Bind FrameCountText(ViewModel.CurrentFrameIndex, ViewModel.MaxFrameIndex), Mode=OneWay}"
                           FontSize="20"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <!-- Previous Frame Button -->
                <Button Grid.Column="1"
                        Style="{StaticResource TransportButtonStyle}"
                        Width="42"
                        Height="42"
                        Click="OnPrevClick"
                        IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                        ToolTipService.ToolTip="Previous frame">
                    <FontIcon Glyph="&#xE892;" 
                              FontSize="16"/>
                </Button>
                <!-- Play/Stop Button -->
                <Button Grid.Column="2"
                        Style="{StaticResource TransportButtonStyle}"
                        Width="60"
                        Height="60"
                        Click="OnPlayStopClick"
                        IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                        ToolTipService.ToolTip="Play / stop (stop returns to the newest frame)">
                    <FontIcon Glyph="{x:Bind PlayStopGlyph(ViewModel.IsPlaying), Mode=OneWay}"
                              FontSize="24"/>
                </Button>
                <!-- Next Frame Button -->
                <Button Grid.Column="3"
                        Style="{StaticResource TransportButtonStyle}"
                        Width="42"
                        Height="42"
                        Click="OnNextClick"
                        IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                        ToolTipService.ToolTip="Next frame">
                    <FontIcon Glyph="&#xE893;"
                              FontSize="16"/>
                </Button>
                <!-- The displayed frame's time, right of the buttons (slightly larger). -->
                <TextBlock Grid.Column="4"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.CurrentFrameTimeText, Mode=OneWay}"
                           FontSize="20"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>

            <!-- Segmented scrubber: one cell per frame (ViewModel.Segments), each lighting up as its frame
                 decodes (per-frame, so cells fill scattered then complete — the load indicator). The playhead
                 is repositioned in code-behind over the current segment; pointer press/drag seeks. -->
            <Grid x:Name="ScrubberHost"
                  Grid.Row="1"
                  Margin="0,10,0,0"
                  Height="16"
                  Background="Transparent"
                  SizeChanged="OnScrubberSizeChanged"
                  PointerPressed="OnScrubberPointerPressed"
                  PointerMoved="OnScrubberPointerMoved"
                  PointerReleased="OnScrubberPointerReleased"
                  PointerCaptureLost="OnScrubberPointerReleased"
                  PointerCanceled="OnScrubberPointerReleased">
                <!-- Always-present track so the scrubber occupies the same footprint whether or not a loop
                     is loaded (the cells render on top as frames decode). -->
                <Border Height="6"
                        VerticalAlignment="Center"
                        CornerRadius="3"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"/>
                <ItemsControl ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              Height="8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:UniformHorizontalPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RadarFrameSegment">
                            <Border Margin="1,0"
                                    CornerRadius="2"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    Opacity="{x:Bind ReadyOpacity, Mode=OneWay}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border x:Name="Playhead"
                        Width="3"
                        Height="16"
                        CornerRadius="1.5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{ThemeResource TextFillColorPrimaryBrush}"
                        IsHitTestVisible="False">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="PlayheadTransform"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Grid>

        <!-- ============================ SITE (right of transport) ============================
             Labeled property list (site / time / scan / tilt / loading). Left-aligned at a fixed width so
             it grows only rightward into the empty * space, never nudging the centered transport. -->
        <Grid Grid.Column="2"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Width="350"
              ColumnSpacing="8"
              RowSpacing="3">
            <!-- A reader shouldn't have to already know radar jargon to tell what's what — each label
                 carries a plain-language tooltip explaining the term (VCP, SAILS/MRLE, etc.). -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Site -->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Site"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="The selected radar site: its 4-letter station identifier and location name."/>
            <Grid Grid.Row="0"
                  Grid.Column="1"
                  ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.RadarSiteId, Mode=OneWay}"
                           FontWeight="SemiBold"
                           FontSize="{StaticResource RightClusterFontSize}"/>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.RadarSiteName, Mode=OneWay}"
                           FontSize="{StaticResource RightClusterFontSize}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>
            <!-- Time -->
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Time"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="When this radar frame was scanned."/>
            <!-- Time value + staleness of the freshest frame, side by side. The age font is color-ramped
                 fresh(green)→stale(red) by its age in minutes (AgeBrush), so freshness reads at a glance. -->
            <Grid Grid.Row="1"
                  Grid.Column="1"
                  ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.RadarCardTime, Mode=OneWay}"
                           FontSize="{StaticResource RightClusterFontSize}"/>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.RadarAgeText, Mode=OneWay}"
                           FontSize="{StaticResource RightClusterFontSize}"
                           Foreground="{x:Bind AgeBrush(ViewModel.RadarAgeMinutes), Mode=OneWay}"
                           VerticalAlignment="Center"
                           ToolTipService.ToolTip="How long ago the newest available frame was scanned. Green = fresh, red = stale."/>
            </Grid>
            <!-- Scan -->
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Scan"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="The radar's scan strategy for the whole volume. VCP = Volume Coverage Pattern, a number chosen by the operator: 'precip' patterns scan faster and more often for rain/storms; 'clear-air' patterns scan slower for better sensitivity in dry weather. SAILS/MRLE ×N means the radar squeezes in N extra scans of the lowest tilt per volume, giving fresher data near the ground during fast-changing weather."/>
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Text="{x:Bind RadarVcpText(ViewModel.RadarModeText), Mode=OneWay}"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <!-- Tilt -->
            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Tilt"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="The radar's elevation angle above the horizon — the tilt currently on screen, picked with the Tilt selector. A live loop offers only the lowest few tilts, which the radar scans first and so can show within a few minutes; the higher tilts are scanned late in the volume and are available in Past Event replay."/>
            <TextBlock Grid.Row="3"
                       Grid.Column="1"
                       Text="{x:Bind ViewModel.SelectedTiltLabel, Mode=OneWay}"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
