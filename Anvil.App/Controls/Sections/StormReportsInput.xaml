<?xml version="1.0" encoding="utf-8"?>
<!-- StormReportsInput — the SPC storm-reports verification controls (per-type Tornado / Wind / Hail
     toggles + a count readout + fill opacity + status). Reused in BOTH temporal cards: in the Past card it
     shows the replay day's reports, in the Now card today's — the VM keys the overlay to the active
     convective day, so the same controls serve both. Bound to StormReportsViewModel. -->
<UserControl x:Class="Anvil.Controls.Sections.StormReportsInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ReportLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid ColumnSpacing="12" RowSpacing="10" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- per-type toggles -->
            <RowDefinition Height="Auto"/> <!-- counts -->
            <RowDefinition Height="Auto"/> <!-- opacity -->
            <RowDefinition Height="Auto"/> <!-- status -->
        </Grid.RowDefinitions>

        <!-- Per-type toggles: each checkbox carries the SPC report color as a swatch. -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Reports" Style="{StaticResource ReportLabelStyle}"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
            <CheckBox MinWidth="0" VerticalAlignment="Center"
                      IsChecked="{x:Bind ViewModel.ShowTornado, Mode=TwoWay}"
                      ToolTipService.ToolTip="Show tornado reports">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Border Width="11" Height="11" CornerRadius="6" Background="#E51919" VerticalAlignment="Center"/>
                    <TextBlock Text="Tornado" Style="{StaticResource ReportLabelStyle}"/>
                </StackPanel>
            </CheckBox>
            <CheckBox MinWidth="0" VerticalAlignment="Center"
                      IsChecked="{x:Bind ViewModel.ShowWind, Mode=TwoWay}"
                      ToolTipService.ToolTip="Show wind reports">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Border Width="11" Height="11" CornerRadius="6" Background="#1663D8" VerticalAlignment="Center"/>
                    <TextBlock Text="Wind" Style="{StaticResource ReportLabelStyle}"/>
                </StackPanel>
            </CheckBox>
            <CheckBox MinWidth="0" VerticalAlignment="Center"
                      IsChecked="{x:Bind ViewModel.ShowHail, Mode=TwoWay}"
                      ToolTipService.ToolTip="Show hail reports">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Border Width="11" Height="11" CornerRadius="6" Background="#18A020" VerticalAlignment="Center"/>
                    <TextBlock Text="Hail" Style="{StaticResource ReportLabelStyle}"/>
                </StackPanel>
            </CheckBox>
        </StackPanel>

        <!-- Count by type for the active convective day (updates as the overlay loads / refreshes). -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Count" Style="{StaticResource ReportLabelStyle}"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" ToolTipService.ToolTip="Tornado reports">
                <Border Width="11" Height="11" CornerRadius="6" Background="#E51919" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind Fmt(ViewModel.TornadoCount), Mode=OneWay}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" ToolTipService.ToolTip="Wind reports">
                <Border Width="11" Height="11" CornerRadius="6" Background="#1663D8" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind Fmt(ViewModel.WindCount), Mode=OneWay}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" ToolTipService.ToolTip="Hail reports">
                <Border Width="11" Height="11" CornerRadius="6" Background="#18A020" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind Fmt(ViewModel.HailCount), Mode=OneWay}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Opacity: overall dot opacity (fill + stroke together). -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Opacity" Style="{StaticResource ReportLabelStyle}"/>
        <Slider Grid.Row="2" Grid.Column="1"
                Width="180" HorizontalAlignment="Left"
                Minimum="0" Maximum="1"
                StepFrequency="0.05" SmallChange="0.05"
                IsThumbToolTipEnabled="False"
                VerticalAlignment="Center"
                Value="{x:Bind ViewModel.Opacity, Mode=TwoWay}"
                ToolTipService.ToolTip="Overall opacity of the storm-report dots"/>

        <!-- Status line (loading / count summary / errors). -->
        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                   TextWrapping="Wrap" FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
    </Grid>
</UserControl>
