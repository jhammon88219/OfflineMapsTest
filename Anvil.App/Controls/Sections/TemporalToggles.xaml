<?xml version="1.0" encoding="utf-8"?>
<!-- TemporalToggles — the left section of the overlay bar: the Past / Now / Fore temporal features, each
     a labeled TWO-PART split button. The LEFT half is the feature toggle (activates the time-frame); the
     RIGHT half is a settings cog that opens/hides that feature's floating settings card above the bar
     (see TemporalCards). The three are INDEPENDENT, deselectable toggles (each on/off on its own click),
     bound to MapViewModel.IsPastCast/IsNowCast/IsForeCast — which project the subsystems' state. Past and
     Now are mutually exclusive (the radar layer is live OR replaying); Fore's outlook overlay stacks on
     either; all three off = a blank basemap. A cog is DISABLED until its feature is toggled on. Icons are
     placeholders — to be sourced later. Bound to the coordinator MapViewModel. -->
<UserControl
    x:Class="Anvil.Controls.Sections.TemporalToggles"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Left half: the feature toggle. Rounded on the left, square on the right so it butts against
             the cog into one control. -->
        <Style x:Key="FeatureToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="6,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <!-- Right half: the settings cog. Narrower, rounded on the right, square on the left. Latches
             (checked) while its card is open; disabled until the feature is on. -->
        <Style x:Key="CogToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0,6,6,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <!-- Section header label (Past / Now / Fore). -->
        <Style x:Key="TemporalLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CharacterSpacing" Value="60"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Style>
        <!-- One section = label over its split button. -->
        <Style x:Key="TemporalSectionStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Spacing" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Simple vertical line between sections. -->
        <Style x:Key="TemporalSeparatorStyle" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="12,3"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Background" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- ===== Past ===== -->
        <StackPanel Style="{StaticResource TemporalSectionStyle}">
            <TextBlock Style="{StaticResource TemporalLabelStyle}" Text="Past"/>
            <!-- Spacing=1 shows the bar surface as a hairline splitting the two halves. -->
            <StackPanel Orientation="Horizontal" Spacing="1" HorizontalAlignment="Center">
                <ToggleButton Style="{StaticResource FeatureToggleStyle}" Content="&#xE81C;"
                              ToolTipService.ToolTip="PastCast — replay a historical radar window"
                              IsChecked="{x:Bind ViewModel.IsPastCast, Mode=TwoWay}"/>
                <ToggleButton Style="{StaticResource CogToggleStyle}" Content="&#xE713;"
                              ToolTipService.ToolTip="PastCast settings"
                              IsEnabled="{x:Bind ViewModel.IsPastCast, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.IsPastCardOpen, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>

        <Border Style="{StaticResource TemporalSeparatorStyle}"/>

        <!-- ===== Now ===== -->
        <StackPanel Style="{StaticResource TemporalSectionStyle}">
            <TextBlock Style="{StaticResource TemporalLabelStyle}" Text="Now"/>
            <StackPanel Orientation="Horizontal" Spacing="1" HorizontalAlignment="Center">
                <ToggleButton Style="{StaticResource FeatureToggleStyle}" Content="&#xE774;"
                              ToolTipService.ToolTip="NowCast — live radar / current conditions"
                              IsChecked="{x:Bind ViewModel.IsNowCast, Mode=TwoWay}"/>
                <ToggleButton Style="{StaticResource CogToggleStyle}" Content="&#xE713;"
                              ToolTipService.ToolTip="NowCast settings"
                              IsEnabled="{x:Bind ViewModel.IsNowCast, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.IsNowCardOpen, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>

        <Border Style="{StaticResource TemporalSeparatorStyle}"/>

        <!-- ===== Fore ===== -->
        <StackPanel Style="{StaticResource TemporalSectionStyle}">
            <TextBlock Style="{StaticResource TemporalLabelStyle}" Text="Fore"/>
            <StackPanel Orientation="Horizontal" Spacing="1" HorizontalAlignment="Center">
                <ToggleButton Style="{StaticResource FeatureToggleStyle}" Content="&#xE706;"
                              ToolTipService.ToolTip="ForeCast — SPC outlooks (latest Day 1 Categorical by default)"
                              IsChecked="{x:Bind ViewModel.IsForeCast, Mode=TwoWay}"/>
                <ToggleButton Style="{StaticResource CogToggleStyle}" Content="&#xE713;"
                              ToolTipService.ToolTip="ForeCast settings"
                              IsEnabled="{x:Bind ViewModel.IsForeCast, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.IsForeCardOpen, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
