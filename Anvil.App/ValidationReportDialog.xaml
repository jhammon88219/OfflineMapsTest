<?xml version="1.0" encoding="utf-8"?>
<!-- ValidationReportDialog — DEV-ONLY. The dealias-validation results pop-up: a summary line over a
     scrollable, read-only monospace dump of the report (Worse volumes first), with Save… (writes the
     markdown to disk via a FileSavePicker) and Close. A ContentDialog like SweepReportDialog. Populated
     from a RadarValidationReport. -->
<ContentDialog x:Class="Anvil.ValidationReportDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="Velocity-dealias validation report"
               PrimaryButtonText="Save…"
               CloseButtonText="Close"
               DefaultButton="Close"
               PrimaryButtonClick="OnSaveClick">

    <Grid RowSpacing="8" Width="720" Height="460">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="SummaryText" Grid.Row="0" TextWrapping="Wrap"
                   FontWeight="SemiBold"/>

        <!-- Read-only monospace body so the columns line up; scrolls for the full report. -->
        <TextBox x:Name="ReportText" Grid.Row="1"
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                 FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Grid>
</ContentDialog>
