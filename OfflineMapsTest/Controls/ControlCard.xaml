<?xml version="1.0" encoding="utf-8"?>
<!-- ControlCard — the reusable chrome for a temporal feature's settings card that floats just above the
     OverlayBar. It's a fixed-size, theme-aware panel (SAME opaque surface + border as the bar, from the
     shared OverlayBarSurfaceBrush) with a header (title + a down-triangle that HIDES the card) over a
     content slot (CardBody). Fixed size on purpose: every temporal card is the same footprint; less-busy
     cards just carry unused space for now. The triangle raises CloseRequested — hiding the card does NOT
     disable the feature (the host clears only the open-card state). -->
<UserControl
    x:Class="OfflineMapsTest.Controls.ControlCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- One fixed footprint for EVERY temporal card (deliberately larger than any current body needs —
         less-busy cards just carry empty space for now). Editing a card body won't change the card size. -->
    <Border Width="460" Height="260"
            Background="{ThemeResource OverlayBarSurfaceBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid Margin="16,10,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: title on the left, down-triangle (hide) on the right. -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind Title, Mode=OneWay}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           CharacterSpacing="40"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <!-- Down-triangle: collapses the card down toward the bar (chevron-down, E70D). -->
                <Button Grid.Column="1"
                        Click="OnCloseClick"
                        Width="28" Height="24"
                        Padding="0"
                        MinWidth="0" MinHeight="0"
                        CornerRadius="6"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Hide this panel">
                    <FontIcon Glyph="&#xE70D;"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="12"/>
                </Button>
            </Grid>

            <!-- Feature controls. -->
            <ContentPresenter Grid.Row="1"
                              VerticalAlignment="Top"
                              Content="{x:Bind CardBody, Mode=OneWay}"/>
        </Grid>
    </Border>
</UserControl>
