<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     OverlayBar — a CHROME-ONLY shell: the centered show/hide pull-tab, the theme-aware
     surface + hairline card border (wrapping the tab), and the bottom-overlay collapse behavior. It is a
     content slot: the host fills BarContent with the actual controls (loop transport,
     product selectors, …), so section content is composed in MainWindow, not here.
     (Named for what it IS — a bottom overlay shell — not for what it happens to host;
     the actual radar transport lives in the RadarControls section it hosts.)

     It renders as a bottom OVERLAY: the host places it VerticalAlignment=Bottom over the
     full-height map, so showing/hiding the bar never resizes the map. The control's own
     backdrop is transparent — only the tab and the bar draw — so the map shows through
     beside the centered tab.

     The show/hide state (IsOverlayBarVisible) is pure view state and lives on this
     control, not a view model.
     ============================================================================ -->
<UserControl
    x:Class="OfflineMapsTest.Controls.OverlayBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- The opaque surface + hover brushes (OverlayBarSurfaceBrush / …HoverBrush) are defined
                 app-wide in Controls/Styles.xaml so the floating settings cards can share them; they
                 resolve here via ThemeResource and follow the Win11 light/dark setting at runtime. -->

            <!-- The centered pull-tab: a flat-bottomed tab that reads as attached to the bar's top edge
                 (bottom border omitted; the negative bottom margin laps over the bar's top border so the two merge).
                 A minimal template keeps it fully opaque in every state — no default-template overlay can
                 introduce translucency; hover/press only swap to an explicit opaque color. -->
            <Style x:Key="OverlayBarTabStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource OverlayBarSurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
                <Setter Property="BorderThickness" Value="1,1,1,0"/>
                <Setter Property="CornerRadius" Value="7,7,0,0"/>
                <Setter Property="Padding" Value="16,3"/>
                <!-- Lap the tab's (borderless) bottom over the bar's 1px top border so the two merge into
                     one hairline that wraps the tab — with no border line showing across the tab bottom.
                     -2 (not -1) so the opaque tab body fully covers the bar's top border across DPI scales
                     (a 1px lap left a subpixel sliver of the border visible under the tab). -->
                <Setter Property="Margin" Value="0,0,0,-2"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource OverlayBarSurfaceHoverBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource OverlayBarSurfaceHoverBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Transparent root: only the tab + bar draw, so the map shows through beside the tab.
         This control is ONLY the chrome (tab + bar). The floating windows that pop above it (the temporal
         settings cards, the app settings card, the site explorer) are NOT hosted here — they live in
         MainWindow's floating layer, the row directly above this control, so every one of them shares the
         same FloatingWindowMargin off the bar and the window edges. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- pull-tab -->
            <RowDefinition Height="Auto"/> <!-- overlay bar (collapses when hidden) -->
        </Grid.RowDefinitions>

        <!-- The bar itself: a content slot the host fills (see BarContent). Collapses when hidden. Its top
             border + the tab's left/top/right border (below) share ONE brush and merge where the tab meets
             the bar, so the hairline runs along the bar top and wraps AROUND the tab (never through it). -->
        <Border x:Name="BarBorder" Grid.Row="1" Background="{ThemeResource OverlayBarSurfaceBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{x:Bind VisibleWhen(IsOverlayBarVisible), Mode=OneWay}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}" Padding="16,10">
            <ContentPresenter HorizontalAlignment="Stretch" Content="{x:Bind BarContent, Mode=OneWay}"/>
        </Border>

        <!-- Centered pull-tab: reads Hide (bar showing) / Show (bar hidden). A flat-bottomed tab with a
             left/top/right border (OverlayBarTabStyle) that laps -1px over the bar's top border, so the
             two merge into one hairline that wraps around the tab. -->
        <Button x:Name="TabButton" Grid.Row="0" Style="{StaticResource OverlayBarTabStyle}"
                Click="OnToggleOverlayBarClick"
                ToolTipService.ToolTip="Show / hide the loop controls">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon Glyph="{x:Bind ToggleGlyph(IsOverlayBarVisible), Mode=OneWay}"
                          FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ToggleLabel(IsOverlayBarVisible), Mode=OneWay}"
                           FontSize="15" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
