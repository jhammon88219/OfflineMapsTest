<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     OverlayBar — a CHROME-ONLY shell: the centered show/hide pull-tab, the accent drop
     shadow, the theme-aware surface, and the bottom-overlay collapse behavior. It is a
     content slot: the host fills BarContent with the actual controls (loop transport,
     product selectors, …), so section content is composed in MainWindow, not here.
     (Named for what it IS — a bottom overlay shell — not for what it happens to host;
     the round play/scrub control it hosts is the actual "transport control", RadialTransport.)

     It renders as a bottom OVERLAY: the host places it VerticalAlignment=Bottom over the
     full-height map, so showing/hiding the bar never resizes the map. The control's own
     backdrop is transparent — only the tab and the bar draw — so the map shows through
     beside the centered tab.

     The show/hide state (IsOverlayBarVisible) is pure view state and lives on this
     control, not a view model.
     ============================================================================ -->
<UserControl
    x:Class="OfflineMapsTest.Controls.OverlayBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Opaque surface + hover brushes, defined per theme so the bar/tab follow the Windows 11
                 light/dark setting at runtime (ThemeResource re-evaluates on theme change) while we keep
                 exact control of the look and full opacity. Border/text reuse the system theme brushes. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="OverlayBarSurfaceBrush" Color="#FF1C1C1C"/>
                    <SolidColorBrush x:Key="OverlayBarSurfaceHoverBrush" Color="#FF2A2A2A"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="OverlayBarSurfaceBrush" Color="#FFF3F3F3"/>
                    <SolidColorBrush x:Key="OverlayBarSurfaceHoverBrush" Color="#FFE4E4E4"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="OverlayBarSurfaceBrush" Color="{ThemeResource SystemColorButtonFaceColor}"/>
                    <SolidColorBrush x:Key="OverlayBarSurfaceHoverBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- The centered pull-tab: a flat-bottomed tab that reads as attached to the bar's top edge
                 (bottom border omitted; -1 bottom margin laps over the bar's top border so the two merge).
                 A minimal template keeps it fully opaque in every state — no default-template overlay can
                 introduce translucency; hover/press only swap to an explicit opaque color. -->
            <Style x:Key="OverlayBarTabStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource OverlayBarSurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
                <Setter Property="BorderThickness" Value="1,1,1,0"/>
                <Setter Property="CornerRadius" Value="7,7,0,0"/>
                <Setter Property="Padding" Value="16,3"/>
                <Setter Property="Margin" Value="0,0,0,-1"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource OverlayBarSurfaceHoverBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource OverlayBarSurfaceHoverBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Transparent root: only the tab + bar draw, so the map shows through beside the tab. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- pull-tab -->
            <RowDefinition Height="Auto"/> <!-- overlay bar (collapses when hidden) -->
        </Grid.RowDefinitions>

        <!-- Shadow host: spans both rows, BEHIND everything (declared first). Code-behind draws the
             accent glows for both the bar and the tab into one container visual here. Because it's
             below the tab in z-order, no glow can cross in front of the tab. -->
        <Border x:Name="ShadowHost" Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False"/>

        <!-- The bar itself: a content slot the host fills (see BarContent). Collapses when hidden. -->
        <Border x:Name="BarBorder" Grid.Row="1" Background="{ThemeResource OverlayBarSurfaceBrush}"
                BorderThickness="0,1,0,0" SizeChanged="OnLayoutChanged"
                Visibility="{x:Bind VisibleWhen(IsOverlayBarVisible), Mode=OneWay}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}" Padding="16,10">
            <ContentPresenter HorizontalAlignment="Stretch" Content="{x:Bind BarContent, Mode=OneWay}"/>
        </Border>

        <!-- Centered pull-tab: reads Hide (bar showing) / Show (bar hidden). Declared LAST so it's
             top-most — its own glow (and the bar's) is drawn in the ShadowHost below it, so nothing
             renders in front of the tab. -->
        <Button x:Name="TabButton" Grid.Row="0" Style="{StaticResource OverlayBarTabStyle}"
                Click="OnToggleOverlayBarClick" SizeChanged="OnLayoutChanged"
                ToolTipService.ToolTip="Show / hide the loop controls">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon Glyph="{x:Bind ToggleGlyph(IsOverlayBarVisible), Mode=OneWay}"
                          FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ToggleLabel(IsOverlayBarVisible), Mode=OneWay}"
                           FontSize="15" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
