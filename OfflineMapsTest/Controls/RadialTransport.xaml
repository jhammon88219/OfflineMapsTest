<?xml version="1.0" encoding="utf-8"?>
<!-- RadialTransport — a round transport control that fuses play/stop + the scrubber into one dial:
     an outer ring shows the loop position (drag it to seek), and the round center button plays
     (▶ when stopped) / stops (■ when playing; stop returns to the newest frame). The current frame
     time is shown by the host (RadarControls puts it to the right of the dial), not here. Binds a
     slice of RadarViewModel. Geometry + pointer scrubbing live in code-behind. -->
<UserControl
    x:Class="OfflineMapsTest.Controls.RadialTransport"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- The dial. Transparent background so it receives pointer events across the ring/gap; the
         center button (on top) intercepts its own presses. -->
    <Grid x:Name="Dial" Width="150" Height="150" Background="Transparent"
          PointerPressed="OnDialPointerPressed" PointerMoved="OnDialPointerMoved"
          PointerReleased="OnDialPointerReleased" PointerCanceled="OnDialPointerReleased"
          PointerCaptureLost="OnDialPointerReleased">
        <!-- Track (full faint ring). -->
        <Ellipse Width="150" Height="150" Fill="Transparent" StrokeThickness="10"
                 Stroke="{ThemeResource ControlStrokeColorSecondaryBrush}"/>
        <!-- Progress arc (Data set in code from the current fraction). -->
        <shapes:Path x:Name="ProgressArc" StrokeThickness="10"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                     StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        <!-- Draggable thumb (positioned in code via Margin). -->
        <Ellipse x:Name="Thumb" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Fill="{ThemeResource TextFillColorPrimaryBrush}" StrokeThickness="2"
                 Stroke="{ThemeResource AccentFillColorDefaultBrush}"/>
        <!-- Round center button: play / stop. -->
        <Button x:Name="CenterButton" Width="92" Height="92" CornerRadius="46" Padding="0"
                HorizontalAlignment="Center" VerticalAlignment="Center" Click="OnCenterClick"
                IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                ToolTipService.ToolTip="Play / stop">
            <Grid>
                <FontIcon x:Name="PlayIcon" Glyph="&#xE768;" FontSize="28"/>
                <FontIcon x:Name="StopIcon" Glyph="&#xE71A;" FontSize="24" Visibility="Collapsed"/>
            </Grid>
        </Button>
    </Grid>
</UserControl>
