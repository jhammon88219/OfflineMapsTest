<?xml version="1.0" encoding="utf-8"?>
<!-- ContextBar — the right section of the transport bar: each enabled temporal feature's options shown
     INLINE here (no flyout). For now it hosts the Past Event input form (shown while PastCast /
     Radar.IsPastEventMode is on). As more temporal features are enabled, they add their own inline
     sections here. -->
<UserControl
    x:Class="OfflineMapsTest.Controls.Sections.ContextBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sections="using:OfflineMapsTest.Controls.Sections"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <!-- Past event date/start/window form, inline — appears when PastCast is toggled on. -->
        <sections:PastEventInput ViewModel="{x:Bind ViewModel.Radar, Mode=OneWay}"
                                 Visibility="{x:Bind VisibleWhen(ViewModel.Radar.IsPastEventMode), Mode=OneWay}"/>
    </StackPanel>
</UserControl>
