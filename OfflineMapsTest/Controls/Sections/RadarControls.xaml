<?xml version="1.0" encoding="utf-8"?>
<!-- RadarControls — the merged center section of the transport bar (loop transport + product were
     recombined onto one view/one RadarViewModel): the radar display controls (product, tilt,
     show/hide sites) stacked to the LEFT of the round RadialTransport dial, and the selected-site
     info + frame time + scan mode stacked to the RIGHT of it. All bound to RadarViewModel. -->
<UserControl x:Class="OfflineMapsTest.Controls.Sections.RadarControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="using:OfflineMapsTest.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    
    <UserControl.Resources>
        <x:Double x:Key="RightClusterFontSize">18</x:Double>
    </UserControl.Resources>
    
    <!-- This control STRETCHES to the full bar width, and the dial lives in the center Auto column
         flanked by two EQUAL-STAR columns — so the dial is pinned to the exact horizontal midpoint of
         the bar (== window-center, directly under the show/hide tab) regardless of what the sides show.
         The left cluster right-aligns against the dial at a fixed width; the right cluster left-aligns
         against the dial and, being Auto, grows ONLY rightward into the empty star space — it can widen
         (bigger fonts, long site names) without ever nudging the centered dial. -->
    <Grid ColumnSpacing="35" HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>    <!-- left star: fills to window edge; left cluster hugs the dial -->
            <ColumnDefinition Width="Auto"/> <!-- center: the transport dial (always window-centered) -->
            <ColumnDefinition Width="*"/>    <!-- right star: fills to window edge; right cluster grows into it -->
        </Grid.ColumnDefinitions>

        <!-- Left of the dial: radar display controls, stacked vertically. Fixed width + right-aligned so
             it sits just left of the centered dial (its width is the dial's left counterweight). The color
             bar and both button rows stretch to this width; since the right column (Tilt/Inspect) is a
             fixed 88px, widening here grows only the color bar and the Product/Sites (*) column. -->
        <StackPanel Grid.Column="0"
                    Width="345"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    VerticalAlignment="Center">
            <!-- Color-scale legend for the selected product (Reflectivity / Velocity / CC). Generated from
                 the ramp the WebView pushes (radar-ramps.js) so it always matches the painted gates. The
                 footprint is ALWAYS present (not gated on HasColorScale): before a ramp is known a muted
                 "ghost" bar holds the width so the left cluster doesn't jump when the real ramp fills in.
                 Sits at the top of the left cluster, spanning its full width, above the comboboxes. -->
            <StackPanel Spacing="4">
                <!-- Bar + inspect tick share one cell; the tick is placed by proportional star columns
                     (InspectLeftStar/RightStar) so it tracks the value regardless of the bar's width. -->
                <Grid Height="16">
                    <!-- Ghost placeholder: shown only until a real ramp is known, reserving the bar's size. -->
                    <Border Height="12"
                            VerticalAlignment="Center"
                            CornerRadius="3"
                            BorderThickness="0.5"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            Visibility="{x:Bind GhostVisibility(ViewModel.HasColorScale), Mode=OneWay}"/>
                    <!-- Real ramp: shown once HasColorScale, overlaying (replacing) the ghost. -->
                    <Border Height="12"
                            VerticalAlignment="Center"
                            CornerRadius="3"
                            BorderThickness="0.5"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{x:Bind RampBrush(ViewModel.CurrentRamp), Mode=OneWay}"
                            Visibility="{x:Bind VisibleWhen(ViewModel.HasColorScale), Mode=OneWay}"/>
                    <Grid Visibility="{x:Bind VisibleWhen(ViewModel.IsInspectMarkerVisible), Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{x:Bind InspectLeftStar(ViewModel.InspectFraction), Mode=OneWay}"/>
                            <ColumnDefinition Width="{x:Bind InspectRightStar(ViewModel.InspectFraction), Mode=OneWay}"/>
                        </Grid.ColumnDefinitions>
                        <!-- Live inspect marker: a thin tick at the column boundary = the value under the
                             cursor's fraction along the ramp. -->
                        <Border Grid.Column="1"
                                Width="2"
                                Height="16"
                                HorizontalAlignment="Left"
                                Margin="-1,0,0,0"
                                Background="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </Grid>

                <!-- Numerical scale for the ramp: low / mid / high tick values under the bar. The high
                     tick also carries the unit (dBZ / mph / ρHV) so the reader knows what the numbers are. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind RampScaleMin(ViewModel.CurrentRamp), Mode=OneWay}"
                               FontSize="11"
                               HorizontalAlignment="Left"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind RampScaleMid(ViewModel.CurrentRamp), Mode=OneWay}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Grid.Column="2"
                               Text="{x:Bind RampScaleMax(ViewModel.CurrentRamp), Mode=OneWay}"
                               FontSize="11"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </Grid>
            </StackPanel>

            <!-- Product + Tilt share one row. The two rows below (Product/Tilt and Sites/Inspect) use the
                 SAME column split (* + 88) so Product lines up with the Sites button and Tilt with Inspect. -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          SelectedIndex="{x:Bind ViewModel.RadarProductIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Reflectivity"/>
                    <ComboBoxItem Content="Velocity"/>
                    <ComboBoxItem Content="Correlation Coefficient"/>
                </ComboBox>
                <ComboBox Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          IsEnabled="False"
                          SelectedIndex="0"
                          ToolTipService.ToolTip="Tilt selection is not available yet">
                    <ComboBoxItem Content="0.5&#176;"/>
                </ComboBox>
            </Grid>
            <!-- Show/hide sites + Inspect share one row, using the SAME * + 88 split as the Product/Tilt
                 row above so Sites lines up under Product and Inspect under Tilt. -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Content="{x:Bind ViewModel.RadarSitesToggleLabel, Mode=OneWay}"
                        Click="OnToggleSitesClick"
                        ToolTipService.ToolTip="Show or hide the on-map radar site markers"/>
                <ToggleButton Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Content="Inspect"
                              IsChecked="{x:Bind ViewModel.IsInspecting, Mode=TwoWay}"
                              ToolTipService.ToolTip="Read the value under the cursor on the map, marked live on the color scale"/>
            </Grid>
        </StackPanel>

        <!-- Center: round transport dial (play/stop + ring scrubber). -->
        <ctl:RadialTransport Grid.Column="1"
                             ViewModel="{x:Bind ViewModel}"/>

        <!-- Right of the dial: a labeled property list (site / time / scan / tilt). Capped at MaxWidth=300
             so it grows rightward into the empty star space only up to that width — never wider. -->
        <StackPanel Grid.Column="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Spacing="6">
            <!-- A reader shouldn't have to already know radar jargon to tell what's what — each label
                 carries a plain-language tooltip explaining the term (VCP, SAILS/MRLE, etc.). -->
            <Grid ColumnSpacing="8"
                  RowSpacing="3"
                  MaxWidth="300"
                  HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Site -->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Site"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="The selected radar site: its 4-letter station identifier and location name."/>
            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.RadarSiteId, Mode=OneWay}"
                           FontWeight="SemiBold"
                           FontSize="{StaticResource RightClusterFontSize}"/>
                <TextBlock Text="{x:Bind ViewModel.RadarSiteName, Mode=OneWay}"
                           FontSize="{StaticResource RightClusterFontSize}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <!-- Time -->
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Time"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="When this radar frame was scanned."/>
            <!-- Time value + staleness of the freshest frame, side by side. The age font is color-ramped
                 fresh(green)→stale(red) by its age in minutes (AgeBrush), so freshness reads at a glance. -->
            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.RadarCardTime, Mode=OneWay}"
                           FontSize="{StaticResource RightClusterFontSize}"/>
                <TextBlock Text="{x:Bind ViewModel.RadarAgeText, Mode=OneWay}"
                           FontSize="{StaticResource RightClusterFontSize}"
                           Foreground="{x:Bind AgeBrush(ViewModel.RadarAgeMinutes), Mode=OneWay}"
                           VerticalAlignment="Center"
                           ToolTipService.ToolTip="How long ago the newest available frame was scanned. Green = fresh, red = stale."/>
            </StackPanel>
            <!-- Scan -->
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Scan"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="VCP = Volume Coverage Pattern, the radar's scan strategy (a number chosen by the operator). 'Precip' patterns scan faster and more often for rain/storms; 'clear-air' patterns scan slower for better sensitivity in dry weather."/>
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Text="{x:Bind RadarVcpText(ViewModel.RadarModeText), Mode=OneWay}"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <!-- Tilt -->
            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Tilt"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       ToolTipService.ToolTip="The radar's elevation angle above the horizon (this app always shows the lowest, 0.5° tilt) and how many times it's been rescanned so far this volume — extra low-level rescans (SAILS/MRLE) give fresher data near the ground during fast-changing weather."/>
            <TextBlock Grid.Row="3"
                       Grid.Column="1"
                       Text="{x:Bind RadarSweepText(ViewModel.RadarModeText), Mode=OneWay}"
                       FontSize="{StaticResource RightClusterFontSize}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- 5th row: backfill progress ("Loading 4/10 frames…"), only while older frames are
                 still decoding — collapses once the whole loop is ready, so it never sits there
                 reading "Loading" forever. -->
            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Loading"
                       FontSize="20"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Visibility="{x:Bind LoadingVisibility(ViewModel.RadarLoadingText), Mode=OneWay}"
                       ToolTipService.ToolTip="The newest frame shows right away, but older frames in the loop are decoded in the background — this shows how many are done."/>
            <TextBlock Grid.Row="4"
                       Grid.Column="1"
                       Text="{x:Bind ViewModel.RadarLoadingText, Mode=OneWay}"
                       FontSize="20"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind LoadingVisibility(ViewModel.RadarLoadingText), Mode=OneWay}"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
