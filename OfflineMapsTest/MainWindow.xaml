<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OfflineMapsTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OfflineMapsTest"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:OfflineMapsTest.Models"
    xmlns:vm="using:OfflineMapsTest.ViewModels"
    xmlns:ctl="using:OfflineMapsTest.Controls"
    xmlns:sections="using:OfflineMapsTest.Controls.Sections"
    mc:Ignorable="d"
    Title="OfflineMapsTest">

    <!-- The map fills the whole window; UI (the transport bar) floats on top as an overlay, so
         showing/hiding the bar never changes the map's size. -->
    <Grid Background="#FF0A0A0A">
        <!-- Full-window map (bottom layer; all UI overlays float on top of it). -->
        <controls:WebView2 x:Name="MainMapWebView"/>

        <!-- Overlay bar: a chrome-only shell (Controls/OverlayBar) that floats as a bottom
             overlay. Its content is composed here in three zones — left: temporal-category toggles;
             center: loop controls + product; right: contextual per-feature options buttons. -->
        <ctl:OverlayBar VerticalAlignment="Bottom">
            <ctl:OverlayBar.BarContent>
                <!-- Single overlay cell: RadarControls STRETCHES to full bar width and centers its own
                     dial at window-center (its internal symmetric star grid does the centering); the
                     temporal toggles (far-left) and context options (far-right) float over the empty
                     edges. Overlaying them — rather than giving them their own grid columns — means the
                     dial's position is driven purely by RadarControls, so the edge sections can't shift
                     it and the right-hand site-details can grow rightward into empty space without ever
                     nudging the centered dial. -->
                <Grid>
                    <!-- Center: the merged radar transport + display controls (drives live AND replay). -->
                    <sections:RadarControls HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            ViewModel="{x:Bind ViewModel.Radar}"/>
                    <!-- Left: temporal-category enable toggles. -->
                    <sections:TemporalToggles HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              ViewModel="{x:Bind ViewModel}"/>
                    <!-- Right: contextual options for each enabled feature. -->
                    <sections:ContextBar HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         ViewModel="{x:Bind ViewModel}"/>
                </Grid>
            </ctl:OverlayBar.BarContent>
        </ctl:OverlayBar>

    </Grid>
</Window>
