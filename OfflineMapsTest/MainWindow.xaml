<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OfflineMapsTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OfflineMapsTest"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="OfflineMapsTest">

    <Grid Background="#FF0A0A0A">
        <!-- The main, full-window map. -->
        <controls:WebView2 x:Name="MainMapWebView"/>

        <!-- Control ribbon: an opaque themed bar at the bottom hosting the outlook +
             basemap selectors and a collapse button. -->
        <Border x:Name="Ribbon"
                VerticalAlignment="Bottom"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12"
                Visibility="{x:Bind VisibleWhen(ViewModel.IsRibbonExpanded), Mode=OneWay}">
            <StackPanel Spacing="6">

                <!-- Radar loop controls: play/pause + frame scrubber + frame time, centered as a
                     fixed-width group. Shown only when a radar site is selected; enabled once all
                     frames load. -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Visibility="{x:Bind VisibleWhen(ViewModel.HasRadarLoop), Mode=OneWay}">
                    <Button Padding="10,6"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Play / pause loop"
                            IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                            Click="OnTogglePlayClick">
                        <FontIcon Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}" FontSize="14"/>
                    </Button>
                    <Slider Width="360"
                            VerticalAlignment="Center"
                            Minimum="0"
                            Maximum="{x:Bind ViewModel.MaxFrameIndex, Mode=OneWay}"
                            StepFrequency="1"
                            IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                            Value="{x:Bind ViewModel.CurrentFrameIndex, Mode=TwoWay}"/>
                    <TextBlock VerticalAlignment="Center"
                               MinWidth="110"
                               TextAlignment="Right"
                               Text="{x:Bind ViewModel.CurrentFrameTimeText, Mode=OneWay}"/>
                </StackPanel>

                <!-- Authoritative issued/valid times for the loaded outlook (from its
                     GeoJSON). Hidden when no outlook / no times are available. -->
                <TextBlock Text="{x:Bind ViewModel.OutlookTimesText, Mode=OneWay}"
                           Visibility="{x:Bind VisibleWhen(ViewModel.HasOutlookTimes), Mode=OneWay}"
                           Opacity="0.8"
                           FontSize="12"
                           Margin="2,0,0,2"/>

                <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Radar layer opacity (sites are picked by clicking the on-map markers). -->
                <Slider Grid.Column="0"
                        Width="110"
                        VerticalAlignment="Bottom"
                        Header="Radar Opacity"
                        Minimum="0"
                        Maximum="1"
                        StepFrequency="0.05"
                        SmallChange="0.05"
                        Value="{x:Bind ViewModel.RadarOpacity, Mode=TwoWay}"/>

                <!-- SPC outlook day selector. -->
                <ComboBox Grid.Column="1"
                          MinWidth="140"
                          VerticalAlignment="Bottom"
                          Header="Day"
                          ItemsSource="{x:Bind ViewModel.Days}"
                          SelectedItem="{x:Bind ViewModel.SelectedDayOption, Mode=TwoWay}"
                          DisplayMemberPath="Label"/>

                <!-- SPC outlook product — items cascade to the selected day; the
                     leading "None" entry clears the overlay. -->
                <ComboBox Grid.Column="2"
                          MinWidth="130"
                          VerticalAlignment="Bottom"
                          Header="Outlook"
                          ItemsSource="{x:Bind ViewModel.ProductOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedOption, Mode=TwoWay}"
                          DisplayMemberPath="Label"/>

                <!-- Outlook fill opacity. Outlines stay opaque, so lowering this lets
                     the basemap and its borders read through the polygon fill. -->
                <Slider Grid.Column="3"
                        Width="110"
                        VerticalAlignment="Bottom"
                        Header="Opacity"
                        Minimum="0"
                        Maximum="1"
                        StepFrequency="0.05"
                        SmallChange="0.05"
                        Value="{x:Bind ViewModel.OutlookOpacity, Mode=TwoWay}"/>

                <!-- Basemap style switcher. -->
                <ComboBox Grid.Column="4"
                          MinWidth="150"
                          VerticalAlignment="Bottom"
                          Header="Basemap"
                          ItemsSource="{x:Bind ViewModel.AvailableStyles}"
                          SelectedItem="{x:Bind ViewModel.SelectedStyle, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"/>

                <!-- Show/hide all radar site marker buttons. Independent of the radar layer. -->
                <Button Grid.Column="5"
                        VerticalAlignment="Bottom"
                        Padding="10,8"
                        Content="{x:Bind ViewModel.RadarSitesToggleLabel, Mode=OneWay}"
                        ToolTipService.ToolTip="Show or hide the radar site buttons (does not hide active radar)"
                        Click="OnToggleRadarSitesClick"/>

                <!-- Collapse the whole ribbon. -->
                <Button Grid.Column="7"
                        VerticalAlignment="Bottom"
                        Padding="10,8"
                        ToolTipService.ToolTip="Hide controls"
                        Click="OnCollapseRibbonClick">
                    <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Reveal handle: shown bottom-center only while the ribbon is collapsed, to
             bring the controls back. Opaque themed Border keeps it legible. -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,12"
                CornerRadius="8"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Visibility="{x:Bind VisibleWhen(ViewModel.IsRibbonCollapsed), Mode=OneWay}">
            <Button Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="6"
                    Padding="12,6"
                    Click="OnRevealRibbonClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                    <TextBlock Text="Controls"/>
                </StackPanel>
            </Button>
        </Border>

        <!-- Radar developer diagnostics card (lower-left). Shown only while a radar loop is
             active; floats above the ribbon. Monospace for column alignment. "Copy" puts the
             full event timeline on the clipboard (and writes a file) for pasting into a report. -->
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="14,0,0,150"
                MaxWidth="500"
                CornerRadius="8"
                Padding="14,12"
                Background="#F00F1216"
                BorderBrush="#3300E0FF"
                BorderThickness="1"
                Visibility="{x:Bind VisibleWhen(ViewModel.HasRadarLoop), Mode=OneWay}">
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.RadarDebugText, Mode=OneWay}"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="13"
                           LineHeight="19"
                           Foreground="#EAF6FF"
                           IsTextSelectionEnabled="True"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Copy debug log"
                            Padding="8,3"
                            FontSize="11"
                            Click="OnCopyRadarDebugClick"/>
                    <Button Content="Clear"
                            Padding="8,3"
                            FontSize="11"
                            Click="OnClearRadarDebugClick"/>
                    <TextBlock x:Name="RadarDebugStatus"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="#80E6F7FF"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
