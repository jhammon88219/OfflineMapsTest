<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OfflineMapsTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OfflineMapsTest"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:OfflineMapsTest.Models"
    xmlns:vm="using:OfflineMapsTest.ViewModels"
    mc:Ignorable="d"
    Title="OfflineMapsTest">

    <Grid Background="#FF0A0A0A">
        <!-- A "tool window" card style: a margin-separated, rounded, bordered card on the dock
             backdrop. The border highlights to the system accent when the card holds focus (see
             OnCardGotFocus). A matching caption-bar style sits at the top of each card. (Resources
             live on the Grid — WinUI 3 Window has no Window.Resources.) -->
        <Grid.Resources>
            <Style x:Key="ToolCardStyle" TargetType="Border">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="BorderThickness" Value="1"/>
                <!-- Always-on, theme-aware base border. The "Solid" card stroke is opaque (vs the
                     near-invisible low-alpha CardStrokeColorDefaultBrush), so every card reads as a
                     bordered window at rest; OnCardGotFocus swaps the focused one to the accent. -->
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
                <!-- Opaque (the station behind is transparent, so a low-alpha card fill like
                     CardBackgroundFillColorDefaultBrush would let the map show through the cards). -->
                <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}"/>
            </Style>
            <Style x:Key="ToolCaptionStyle" TargetType="Grid">
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="CornerRadius" Value="5,5,0,0"/>
                <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>
        </Grid.Resources>

        <!-- Full-window map (bottom layer; all UI overlays float on top of it). -->
        <controls:WebView2 x:Name="MainMapWebView"/>

        <!-- ============================================================================
             LEFT tool-window dock — four margin-separated tool-window cards. Collapses to
             the "Tools" reveal button. Each card's border highlights to the accent on focus.
             ============================================================================ -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="300"
                Background="Transparent" BorderThickness="0"
                Visibility="{x:Bind VisibleWhen(ViewModel.IsDockExpanded), Mode=OneWay}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Dock title bar + settings/collapse (transparent — the pane shows the map through). -->
                <Grid Grid.Row="0" Padding="12,8">
                    <TextBlock Text="Tools" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                        <Button Background="Transparent" BorderThickness="0" Padding="6,2"
                                ToolTipService.ToolTip="Settings" Click="OnOpenSettingsClick">
                            <FontIcon Glyph="&#xE713;" FontSize="12"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="6,2"
                                ToolTipService.ToolTip="Collapse tools" Click="OnToggleDockClick">
                            <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Four tool-window cards, equal vertical quarters -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TW1: Radar Sites -->
                    <Border Grid.Row="0" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                                <TextBlock Text="Radar Sites" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <!-- Site rows styled to match the on-map site buttons: a graphite chip
                                 when available, the orange accent when selected, and a muted red
                                 "down" chip (disabled, so it isn't clickable) when offline. The row
                                 visuals come from overriding the ListViewItem state brushes below;
                                 the template text intentionally sets NO Foreground so it inherits the
                                 container's state-aware foreground (light → dark-on-orange → red). -->
                            <ListView x:Name="RadarSitesListView" Grid.Row="1" Background="Transparent"
                                      ItemsSource="{x:Bind ViewModel.RadarSiteRows}"
                                      SelectionMode="Single"
                                      SelectedItem="{x:Bind ViewModel.SelectedSiteRow, Mode=TwoWay}">
                                <ListView.Resources>
                                    <!-- Available (rest) = graphite key; hover/pressed = a touch lighter. -->
                                    <SolidColorBrush x:Key="ListViewItemBackground" Color="#33333A"/>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#3F3F47"/>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#2C2C32"/>
                                    <SolidColorBrush x:Key="ListViewItemForeground" Color="#F3F3F3"/>
                                    <SolidColorBrush x:Key="ListViewItemForegroundPointerOver" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="ListViewItemForegroundPressed" Color="#FFFFFF"/>
                                    <!-- Selected = orange accent with dark text (matches the latched button). -->
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#F58A12"/>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#FF9A2E"/>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#E07D0C"/>
                                    <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#2A1300"/>
                                    <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="#2A1300"/>
                                    <SolidColorBrush x:Key="ListViewItemForegroundSelectedPressed" Color="#2A1300"/>
                                    <!-- Down (offline) = dead red key. Reached via the disabled state,
                                         since the row's IsEnabled is bound to IsAvailable below. -->
                                    <SolidColorBrush x:Key="ListViewItemBackgroundDisabled" Color="#2E1B1E"/>
                                    <SolidColorBrush x:Key="ListViewItemForegroundDisabled" Color="#E89B9B"/>
                                    <!-- Background already carries the orange selection; drop the pill. -->
                                    <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="Transparent"/>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                        <Setter Property="CornerRadius" Value="6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <!-- Down rows aren't clickable. -->
                                        <Setter Property="IsEnabled" Value="{Binding IsAvailable}"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RadarSiteRow">
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Id}" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind Name}" FontSize="11" Opacity="0.75"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- TW2: Radar Loop -->
                    <Border Grid.Row="1" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                                <TextBlock Text="Radar Loop" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Padding="10,8" Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Padding="9,5" IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                                                ToolTipService.ToolTip="Play / pause" Click="OnTogglePlayClick">
                                            <FontIcon Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}" FontSize="13"/>
                                        </Button>
                                        <Button Padding="9,5" IsEnabled="{x:Bind ViewModel.CanStopLoop, Mode=OneWay}"
                                                ToolTipService.ToolTip="Stop — halt playback and return to the newest frame"
                                                Click="OnStopLoopClick">
                                            <FontIcon Glyph="&#xE71A;" FontSize="13"/>
                                        </Button>
                                        <TextBlock VerticalAlignment="Center" Margin="4,0,0,0"
                                                   Text="{x:Bind ViewModel.CurrentFrameTimeText, Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <Slider Minimum="0" Maximum="{x:Bind ViewModel.MaxFrameIndex, Mode=OneWay}"
                                            StepFrequency="1" IsEnabled="{x:Bind ViewModel.IsLoopReady, Mode=OneWay}"
                                            Value="{x:Bind ViewModel.CurrentFrameIndex, Mode=TwoWay}"/>
                                    <ComboBox Header="Product" HorizontalAlignment="Stretch"
                                              SelectedIndex="{x:Bind ViewModel.RadarProductIndex, Mode=TwoWay}">
                                        <ComboBoxItem>Reflectivity</ComboBoxItem>
                                        <ComboBoxItem>Velocity</ComboBoxItem>
                                        <ComboBoxItem>Correlation Coeff</ComboBoxItem>
                                    </ComboBox>
                                    <ComboBox Header="Tilt" HorizontalAlignment="Stretch" IsEnabled="False" SelectedIndex="0">
                                        <ComboBoxItem>0.5°</ComboBoxItem>
                                    </ComboBox>
                                    <!-- Loop length + Update interval are live-only concepts; gray out in Past mode. -->
                                    <ComboBox Header="Loop length (frames)" HorizontalAlignment="Stretch"
                                              IsEnabled="{x:Bind ViewModel.IsLiveControlsEnabled, Mode=OneWay}"
                                              ItemsSource="{x:Bind ViewModel.LoopLengthOptions}"
                                              SelectedIndex="{x:Bind ViewModel.LoopLengthIndex, Mode=TwoWay}"/>
                                    <ComboBox Header="Update interval" HorizontalAlignment="Stretch"
                                              IsEnabled="{x:Bind ViewModel.IsLiveControlsEnabled, Mode=OneWay}"
                                              ItemsSource="{x:Bind ViewModel.RefreshIntervalOptions}"
                                              SelectedIndex="{x:Bind ViewModel.RefreshIntervalIndex, Mode=TwoWay}"/>
                                    <ComboBox Header="Playback speed" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.PlaybackSpeedOptions}"
                                              SelectedIndex="{x:Bind ViewModel.PlaybackSpeedIndex, Mode=TwoWay}"/>
                                    <Slider Header="Radar Opacity" Minimum="0" Maximum="1" StepFrequency="0.05"
                                            Value="{x:Bind ViewModel.RadarOpacity, Mode=TwoWay}"/>
                                    <ToggleButton HorizontalAlignment="Stretch"
                                                  IsChecked="{x:Bind ViewModel.IsInspecting, Mode=OneWay}"
                                                  IsEnabled="{x:Bind ViewModel.HasRadarDisplay, Mode=OneWay}"
                                                  ToolTipService.ToolTip="Inspect — read the product value under the cursor"
                                                  Click="OnToggleInspectClick">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE721;" FontSize="13"/>
                                            <TextBlock Text="Inspect"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <Button HorizontalAlignment="Stretch"
                                            Content="{x:Bind ViewModel.RadarSitesToggleLabel, Mode=OneWay}"
                                            ToolTipService.ToolTip="Show or hide the on-map site markers"
                                            Click="OnToggleRadarSitesClick"/>
                                    <Button HorizontalAlignment="Stretch"
                                            IsEnabled="{x:Bind AllTrue(ViewModel.HasRadarLoop, ViewModel.IsLiveControlsEnabled), Mode=OneWay}"
                                            ToolTipService.ToolTip="Dump all frames and reload the live loop from scratch"
                                            Click="OnResetLoopClick">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                                            <TextBlock Text="Reset loop"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- TW3: Outlook -->
                    <Border Grid.Row="2" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                                <TextBlock Text="Outlook" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Padding="10,8" Spacing="8">
                                    <!-- Master on/off for the outlook overlay (off at launch). The
                                         Day/Outlook combos below arm WHICH outlook; this draws it. -->
                                    <ToggleSwitch Header="Show outlook layer" OnContent="On" OffContent="Off"
                                                  IsOn="{x:Bind ViewModel.IsOutlookVisible, Mode=TwoWay}"/>
                                    <!-- SPC watch boxes — Tornado / Severe Thunderstorm Watches
                                         (independent of the outlook). -->
                                    <ToggleSwitch Header="SPC Watches" OnContent="On" OffContent="Off"
                                                  IsOn="{x:Bind ViewModel.ShowWatches, Mode=TwoWay}"/>
                                    <ComboBox Header="Day" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.Days}"
                                              SelectedItem="{x:Bind ViewModel.SelectedDayOption, Mode=TwoWay}"
                                              DisplayMemberPath="Label"/>
                                    <ComboBox Header="Outlook" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.ProductOptions, Mode=OneWay}"
                                              SelectedItem="{x:Bind ViewModel.SelectedOption, Mode=TwoWay}"
                                              DisplayMemberPath="Label"/>
                                    <Slider Header="Opacity" Minimum="0" Maximum="1" StepFrequency="0.05"
                                            Value="{x:Bind ViewModel.OutlookOpacity, Mode=TwoWay}"/>
                                    <!-- Countdown + progress to the next SPC outlook refresh (~15 min). -->
                                    <StackPanel Spacing="3" Margin="0,4,0,0">
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Next outlook update ·"/>
                                            <Run Text="{x:Bind ViewModel.OutlookNextUpdateText, Mode=OneWay}"
                                                 Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </TextBlock>
                                        <ProgressBar Minimum="0" Maximum="100"
                                                     Value="{x:Bind ViewModel.OutlookNextUpdateProgress, Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- TW4: Outlook Details -->
                    <Border Grid.Row="3" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                                <TextBlock Text="Outlook Details" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Padding="10,8" Spacing="5">
                                    <TextBlock Text="{x:Bind ViewModel.OutlookCardTitle, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Issued" Width="56" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.OutlookIssuedText, Mode=OneWay}"
                                                   FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Effective" Width="56" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.OutlookValidText, Mode=OneWay}"
                                                   FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" Padding="10,2,10,8"
                                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{x:Bind ViewModel.OutlookNarrativeText, Mode=OneWay}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11" LineHeight="16"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Reveal button: shown on the left edge only while the dock is collapsed. -->
        <Button HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="14,14,0,0" Padding="10,8" CornerRadius="8"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                ToolTipService.ToolTip="Show tools"
                Visibility="{x:Bind VisibleWhen(ViewModel.IsDockCollapsed), Mode=OneWay}"
                Click="OnToggleDockClick">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                <TextBlock Text="Tools"/>
            </StackPanel>
        </Button>

        <!-- ============================================================================
             RIGHT tool-window dock — stacks tool windows from the top: "Selected Site" (the
             radar readout, shown only while a site is selected) and "Map" (basemap selector +
             future map controls, always shown). Cards are Auto-height so they hug the top; the
             trailing "*" filler row lets the map show through below them.
             ============================================================================ -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="300"
                Background="Transparent" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            <!-- TW: Selected Site -->
            <Border Grid.Row="0" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus"
                    Visibility="{x:Bind VisibleWhen(ViewModel.HasRadarLoop), Mode=OneWay}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                        <TextBlock Text="Selected Site" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel VerticalAlignment="Top" Padding="16,14" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                         Fill="{x:Bind RadarDotBrush(ViewModel.RadarStatus), Mode=OneWay}"/>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.RadarCardTitle, Mode=OneWay}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.RadarCardCoords, Mode=OneWay}"
                                               FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="1">
                                <TextBlock Text="{x:Bind ViewModel.RadarCardTime, Mode=OneWay}"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.RadarFrameDetail, Mode=OneWay}"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Mode" Width="46" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.RadarModeText, Mode=OneWay}"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Updated" Width="46" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.RadarAgeText, Mode=OneWay}"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Loop" Width="46" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.RadarLoopSpanText, Mode=OneWay}"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <!-- Countdown + progress to the next live-frame poll. -->
                                <StackPanel Spacing="3" Margin="0,2,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="Next" Width="46" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.RadarNextFrameText, Mode=OneWay}"
                                                   FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Minimum="0" Maximum="100"
                                                 Value="{x:Bind ViewModel.RadarNextFrameProgress, Mode=OneWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- TW: Color Scale — the active radar product's color ramp, fed from radar-ramps.js (the
                 same stops that color the gates), so the legend can't drift from the pixels. Updates
                 when the product changes; shown while a radar loop is active. -->
            <Border Grid.Row="1" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus"
                    Visibility="{x:Bind VisibleWhen(ViewModel.HasColorScale), Mode=OneWay}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                        <TextBlock Text="Color Scale" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Padding="14,10" Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.RampTitle, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <!-- The gradient bar + a live inspect marker (a thin tick positioned along the
                             ramp by the value under the cursor). The marker grid overlays the bar; its
                             star columns place the tick at the value's fraction. -->
                        <Grid>
                            <Border Height="16" CornerRadius="3" BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                                    Background="{x:Bind RampBrush(ViewModel.CurrentRamp), Mode=OneWay}"/>
                            <Grid Visibility="{x:Bind VisibleWhen(ViewModel.IsInspectMarkerVisible), Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{x:Bind InspectLeftStar(ViewModel.InspectFraction), Mode=OneWay}"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="{x:Bind InspectRightStar(ViewModel.InspectFraction), Mode=OneWay}"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Width="3" Height="24" CornerRadius="1.5"
                                        Background="White" BorderBrush="Black" BorderThickness="1"
                                        VerticalAlignment="Center" Margin="-1.5,0,0,0"/>
                            </Grid>
                        </Grid>
                        <Grid>
                            <TextBlock Text="{x:Bind ViewModel.RampMinText, Mode=OneWay}" HorizontalAlignment="Left"
                                       FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.RampMidText, Mode=OneWay}" HorizontalAlignment="Center"
                                       FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.RampMaxText, Mode=OneWay}" HorizontalAlignment="Right"
                                       FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.InspectValueText, Mode=OneWay}"
                                   Visibility="{x:Bind VisibleWhen(ViewModel.IsInspectMarkerVisible), Mode=OneWay}"
                                   HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TW: Selected Marker — editor for the selected map marker (today the user-location
                 marker). Shown only while a marker is selected. Drag the marker on the map to refine
                 its position; this window shows the standing readout (coords + how it was set). -->
            <Border Grid.Row="2" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus"
                    Visibility="{x:Bind VisibleWhen(ViewModel.HasSelectedMarker), Mode=OneWay}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                        <TextBlock Text="Selected Marker" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Padding="16,14" Spacing="12">
                        <!-- Title + descriptive subtitle (kind label, e.g. "My Location"). The accent
                             badge flags the singleton user-location marker (vs future generic pins). -->
                        <StackPanel Spacing="1">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.SelectedMarkerKindLabel, Mode=OneWay}"
                                           FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <Border VerticalAlignment="Center" CornerRadius="9" Padding="8,1"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        Visibility="{x:Bind VisibleWhen(ViewModel.SelectedMarkerIsUserLocation), Mode=OneWay}">
                                    <TextBlock Text="Your location" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.SelectedMarkerSubtitle, Mode=OneWay}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <!-- Coordinates (read-only; refined by dragging the marker on the map). -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Coords" Width="52" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedMarkerCoords, Mode=OneWay}"
                                       FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                        <!-- Source affordance: icon + color say GPS (green) / IP (amber) / manual (blue). -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Source" Width="52" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon FontSize="13" VerticalAlignment="Center"
                                      Glyph="{x:Bind LocationGlyph(ViewModel.SelectedMarkerSource), Mode=OneWay}"
                                      Foreground="{x:Bind LocationBrush(ViewModel.SelectedMarkerSource), Mode=OneWay}"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedMarkerSourceText, Mode=OneWay}"
                                       FontSize="12" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                        <!-- Refine hint + singleton/reset note + remove. -->
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Visibility="{x:Bind VisibleWhen(ViewModel.CanDragSelectedMarker), Mode=OneWay}"
                                   Text="Drag the marker on the map to refine its position."
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Visibility="{x:Bind VisibleWhen(ViewModel.SelectedMarkerIsUserLocation), Mode=OneWay}"
                                   Text="This is your only location marker — press My Location to re-detect (reset) it."
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <Button HorizontalAlignment="Stretch" Click="OnRemoveMarkerClick"
                                ToolTipService.ToolTip="Remove this marker from the map">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                                <TextBlock Text="Remove marker"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TW: Map (basemap selector now; more map controls to come) -->
            <Border Grid.Row="3" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                        <TextBlock Text="Map" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Padding="10,8" Spacing="8">
                        <ComboBox Header="Basemap" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.AvailableStyles}"
                                  SelectedItem="{x:Bind ViewModel.SelectedStyle, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"/>

                        <!-- My Location: resolve via OS, then IP fallback. The placed marker and its
                             standing source readout live in the "Selected Marker" tool window; here we
                             keep only a TRANSIENT in-progress / failure line, so the two don't duplicate. -->
                        <Button HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.CanLocate, Mode=OneWay}"
                                ToolTipService.ToolTip="Find me — device location, falling back to an IP estimate (re-detects / resets an existing marker)"
                                Click="OnMyLocationClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ProgressRing Width="14" Height="14" IsActive="{x:Bind ViewModel.IsLocating, Mode=OneWay}"
                                              Visibility="{x:Bind VisibleWhen(ViewModel.IsLocating), Mode=OneWay}"/>
                                <FontIcon Glyph="&#xE81D;" FontSize="13"
                                          Visibility="{x:Bind VisibleWhen(ViewModel.CanLocate), Mode=OneWay}"/>
                                <TextBlock Text="My Location"/>
                            </StackPanel>
                        </Button>

                        <!-- Transient locate status only ("Locating…" / "Location unavailable"). -->
                        <TextBlock FontSize="11" TextWrapping="Wrap" Margin="2,0,0,0"
                                   Visibility="{x:Bind VisibleWhen(ViewModel.HasLocateStatus), Mode=OneWay}"
                                   Text="{x:Bind ViewModel.LocateStatusText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TW: Past Event Viewer — replay a historical radar window instead of the live loop.
                 The toggle switches the whole radar into replay mode (live controls gray out); pick
                 a site in the Radar Sites list, set a start time + duration, then Load. -->
            <Border Grid.Row="4" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                        <TextBlock Text="Past Event Viewer" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Padding="10,8" Spacing="8">
                        <ToggleSwitch Header="Replay mode" OnContent="On" OffContent="Off"
                                      IsOn="{x:Bind ViewModel.IsPastEventMode, Mode=TwoWay}"/>
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Header="Year" HorizontalAlignment="Stretch"
                                      IsEnabled="{x:Bind ViewModel.IsPastEventMode, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.PastEventYearOptions}"
                                      SelectedIndex="{x:Bind ViewModel.PastEventYearIndex, Mode=TwoWay}"/>
                            <ComboBox Grid.Column="1" Header="Month" HorizontalAlignment="Stretch"
                                      IsEnabled="{x:Bind ViewModel.IsPastEventMode, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.PastEventMonthOptions}"
                                      SelectedIndex="{x:Bind ViewModel.PastEventMonthIndex, Mode=TwoWay}"/>
                            <ComboBox Grid.Column="2" Header="Day" HorizontalAlignment="Stretch"
                                      IsEnabled="{x:Bind ViewModel.IsPastEventMode, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.PastEventDayOptions}"
                                      SelectedIndex="{x:Bind ViewModel.PastEventDayIndex, Mode=TwoWay}"/>
                        </Grid>
                        <TimePicker Header="Start time (local)" HorizontalAlignment="Stretch" ClockIdentifier="12HourClock"
                                    IsEnabled="{x:Bind ViewModel.IsPastEventMode, Mode=OneWay}"
                                    Time="{x:Bind ViewModel.PastEventTime, Mode=TwoWay}"/>
                        <ComboBox Header="Duration" HorizontalAlignment="Stretch"
                                  IsEnabled="{x:Bind ViewModel.IsPastEventMode, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.PastEventDurationOptions}"
                                  SelectedIndex="{x:Bind ViewModel.PastEventDurationIndex, Mode=TwoWay}"/>
                        <Button HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsPastEventMode, Mode=OneWay}"
                                ToolTipService.ToolTip="Load the selected site's radar for this window and scrub it"
                                Click="OnLoadPastEventClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                <TextBlock Text="Load event"/>
                            </StackPanel>
                        </Button>
                        <TextBlock FontSize="11" TextWrapping="Wrap" Margin="2,0,0,0"
                                   Text="{x:Bind ViewModel.PastEventStatus, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TW: DOW Event Viewer — view a curated Doppler-on-Wheels (mobile-radar) frame.
                 Frames are offline-converted with tools/dow_import.py and dropped into
                 Assets/DowEvents; loading one renders it through the normal radar pipeline. -->
            <Border Grid.Row="5" Style="{StaticResource ToolCardStyle}" GotFocus="OnCardGotFocus">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource ToolCaptionStyle}">
                        <TextBlock Text="DOW Event Viewer" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE712;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE718;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Padding="10,8" Spacing="8">
                        <ComboBox Header="Event" HorizontalAlignment="Stretch"
                                  IsEnabled="{x:Bind ViewModel.HasDowEvents, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.DowEvents, Mode=OneWay}"
                                  DisplayMemberPath="Label"
                                  SelectedIndex="{x:Bind ViewModel.DowEventIndex, Mode=TwoWay}"/>
                        <ComboBox Header="Product" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.DowProductOptions}"
                                  SelectedIndex="{x:Bind ViewModel.DowProductIndex, Mode=TwoWay}"/>
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.HasDowEvents, Mode=OneWay}"
                                    ToolTipService.ToolTip="Render the selected DOW frame"
                                    Click="OnLoadDowEventClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                    <TextBlock Text="Load"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" ToolTipService.ToolTip="Clear the DOW frame"
                                    Click="OnClearDowEventClick">
                                <FontIcon Glyph="&#xE711;" FontSize="13"/>
                            </Button>
                        </Grid>
                        <TextBlock FontSize="11" TextWrapping="Wrap" Margin="2,0,0,0"
                                   Text="{x:Bind ViewModel.DowStatus, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
