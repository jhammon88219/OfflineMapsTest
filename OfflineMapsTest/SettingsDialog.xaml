<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="OfflineMapsTest.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="10" Width="460">
        <TextBlock Text="Offline map data" FontWeight="SemiBold" FontSize="14"/>
        <TextBlock TextWrapping="Wrap" FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="The basemap loads from a local PMTiles file. Pick the folder that contains usa_full.pmtiles."/>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderBox" Grid.Column="0" IsReadOnly="True" IsSpellCheckEnabled="False"/>
            <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse…" Click="OnBrowseClick"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon x:Name="StatusIcon" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>
